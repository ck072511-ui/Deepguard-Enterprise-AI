# ============================================================
# DeepGuard — .env.example
# Copy this file to .env and populate with real values.
# NEVER commit .env to version control.
# ============================================================

# ── Application ───────────────────────────────────────────
APP_NAME=DeepGuard
APP_VERSION=1.0.0
APP_ENV=development          # development | staging | production
DEBUG=true
SECRET_KEY=change-this-to-a-strong-random-secret-key-minimum-32-chars
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── API Server ────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true              # Set false in production
API_PREFIX=/api/v1
API_TITLE=DeepGuard API
API_DESCRIPTION=Deepfake Detection System REST API
API_DOCS_URL=/docs
API_REDOC_URL=/redoc

# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./database/deepguard.db
DATABASE_ECHO=false          # Set true to log SQL queries
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Model Configuration ───────────────────────────────────
MODEL_NAME=vit_base_patch16_224
MODEL_PRETRAINED=true
MODEL_NUM_CLASSES=2
MODEL_INPUT_SIZE=224
MODEL_WEIGHTS_PATH=weights/best_model.pt
MODEL_ONNX_PATH=weights/model.onnx
MODEL_DEVICE=auto            # auto | cpu | cuda | mps
MODEL_PRECISION=fp32         # fp32 | fp16 | int8

# ── Inference ─────────────────────────────────────────────
INFERENCE_BATCH_SIZE=8
INFERENCE_MAX_IMAGE_SIZE_MB=10
INFERENCE_MAX_VIDEO_SIZE_MB=200
INFERENCE_CONFIDENCE_THRESHOLD=0.5
INFERENCE_USE_ONNX=false     # Set true for ONNX runtime

# ── MLflow ────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=deepguard-experiments
MLFLOW_ARTIFACT_ROOT=./mlflow/artifacts
MLFLOW_BACKEND_STORE_URI=sqlite:///./mlflow/mlflow.db

# ── Training ──────────────────────────────────────────────
TRAIN_EPOCHS=50
TRAIN_BATCH_SIZE=32
TRAIN_LEARNING_RATE=1e-4
TRAIN_WEIGHT_DECAY=1e-4
TRAIN_NUM_WORKERS=4
TRAIN_SEED=42
TRAIN_GRAD_CLIP=1.0
TRAIN_EARLY_STOPPING_PATIENCE=10

# ── Dataset ───────────────────────────────────────────────
DATASET_ROOT=./datasets
DATASET_NAME=ff++            # ff++ | dfdc | celeb-df | custom
DATASET_SPLIT_RATIO=0.8      # train/val split
DATASET_CACHE_SIZE_GB=5

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json              # json | text
LOG_DIR=./logs
LOG_MAX_SIZE_MB=100
LOG_BACKUP_COUNT=5
LOG_ENABLE_STDOUT=true

# ── Security ──────────────────────────────────────────────
JWT_SECRET_KEY=change-this-jwt-secret-key-must-be-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
API_KEY_HEADER=X-API-Key
RATE_LIMIT_PER_MINUTE=60

# ── Monitoring ────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
HEALTH_CHECK_INTERVAL_SECONDS=30

# ── Storage ───────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=200
CLEANUP_TEMP_FILES=true
TEMP_FILE_TTL_HOURS=24

# ── Cache ─────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE_MB=512
CACHE_BACKEND=disk           # memory | disk

# ── ONNX Runtime ──────────────────────────────────────────
ONNX_PROVIDERS=CPUExecutionProvider  # CUDAExecutionProvider,CPUExecutionProvider
ONNX_INTER_OP_THREADS=4
ONNX_INTRA_OP_THREADS=4

# ── Feature Flags ─────────────────────────────────────────
FEATURE_VIDEO_ANALYSIS=true
FEATURE_BATCH_PROCESSING=true
FEATURE_FACE_DETECTION=true
FEATURE_HEATMAP_GENERATION=true
FEATURE_EXPLAINABILITY=true
